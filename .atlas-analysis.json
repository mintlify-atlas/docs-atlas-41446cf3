  "keyFeatures": [
    "TR-069/CWMP protocol support for remote device management",
    "Declarative provisioning engine with JavaScript scripting",
    "Northbound REST API (NBI) for OSS/BSS integration",
    "Virtual parameters for computed/derived device values",
    "Extension system for external integrations",
    "Role-based access control with expression-based permissions",
    "Scales to millions of concurrent CPE devices",
    "Multi-service architecture: CWMP, NBI, FS, UI"
  ],
  "publicApiSurface": [
    "GET /<collection>/?query=<query> — Search devices, tasks, presets, objects",
    "POST /devices/<device_id>/tasks — Enqueue device tasks",
    "POST /tasks/<task_id>/retry — Retry a failed task",
    "DELETE /tasks/<task_id> — Delete a task",
    "DELETE /faults/<fault_id> — Delete a fault",
    "DELETE /devices/<device_id> — Remove a device",
    "POST /devices/<device_id>/tags/<tag> — Assign tag to device",
    "DELETE /devices/<device_id>/tags/<tag> — Remove tag from device",
    "PUT /presets/<preset_name> — Create or update preset",
    "DELETE /presets/<preset_name> — Delete preset",
    "PUT /files/<file_name> — Upload firmware/config file",
    "DELETE /files/<file_name> — Delete file",
    "GET /files/ — List all files",
    "PUT /provisions/<name> — Create or update provision script",
    "DELETE /provisions/<name> — Delete provision script",
    "GET /provisions/ — List all provisions"
  ]
}
